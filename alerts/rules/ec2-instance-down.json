{
  "name": "ec2-instance-down",
  "folderUID": "",
  "interval": 60,
  "rules": [
    {
      "title": "EC2 Instance i-0e9c981e03dfb6392 Down",
      "condition": "C",
      "for": "2m",
      "noDataState": "Alerting",
      "execErrState": "Alerting",
      "labels": {
        "severity": "critical",
        "instance_id": "i-0e9c981e03dfb6392",
        "team": "ops"
      },
      "annotations": {
        "summary": "EC2 instance i-0e9c981e03dfb6392 is down",
        "description": "Instance i-0e9c981e03dfb6392 has failed its status check for more than 2 minutes. Immediate action required.",
        "runbook_url": "https://wiki.example.com/runbooks/ec2-instance-down"
      },
      "data": [
        {
          "refId": "A",
          "relativeTimeRange": { "from": 300, "to": 0 },
          "datasourceUid": "${CLOUDWATCH_DATASOURCE_UID}",
          "model": {
            "alias": "Status Check Failed",
            "dimensions": {
              "InstanceId": ["i-0e9c981e03dfb6392"]
            },
            "expression": "",
            "highResolution": false,
            "id": "",
            "matchExact": true,
            "metricName": "StatusCheckFailed",
            "metricQueryType": 0,
            "metricEditorMode": 0,
            "namespace": "AWS/EC2",
            "period": "60",
            "queryMode": "Metrics",
            "refId": "A",
            "region": "default",
            "statistic": "Maximum"
          }
        },
        {
          "refId": "B",
          "relativeTimeRange": { "from": 300, "to": 0 },
          "datasourceUid": "__expr__",
          "model": {
            "conditions": [
              {
                "evaluator": { "params": [1], "type": "gt" },
                "operator":  { "type": "and" },
                "query":     { "params": ["A"] },
                "reducer":   { "params": [], "type": "last" },
                "type":      "query"
              }
            ],
            "datasource": { "type": "__expr__", "uid": "__expr__" },
            "expression": "A",
            "intervalMs": 1000,
            "maxDataPoints": 43200,
            "refId": "B",
            "type": "classic_conditions"
          }
        },
        {
          "refId": "C",
          "relativeTimeRange": { "from": 300, "to": 0 },
          "datasourceUid": "__expr__",
          "model": {
            "conditions": [
              {
                "evaluator": { "params": [0], "type": "gt" },
                "operator":  { "type": "and" },
                "query":     { "params": ["B"] },
                "reducer":   { "params": [], "type": "last" },
                "type":      "query"
              }
            ],
            "datasource": { "type": "__expr__", "uid": "__expr__" },
            "expression": "B",
            "intervalMs": 1000,
            "maxDataPoints": 43200,
            "refId": "C",
            "type": "classic_conditions"
          }
        }
      ]
    }
  ]
}
